# Runtime
NODE_ENV=production
RUNTIME_MODE=API
PORT=3000
TRUST_PROXY_HOPS=1
CORS_ALLOWED_ORIGINS=https://app.example.com
PRISMA_MIGRATIONS_PATH=prisma/migrations

# PostgreSQL
POSTGRES_DB=nutrafit
POSTGRES_USER=nutrafit
POSTGRES_PASSWORD=replace-with-a-long-database-password
DATABASE_URL=postgresql://nutrafit:replace-with-a-long-database-password@localhost:5432/nutrafit?schema=public
API_PORT=3000

# Authentication
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-32-character-secret
JWT_ISSUER=nutrafit-api
JWT_AUDIENCE=nutrafit-app

# Plans and subscriptions
BASIC_DAILY_IMAGE_LIMIT=5
PREMIUM_DAILY_IMAGE_LIMIT=999999
SUBSCRIPTION_GRACE_PERIOD_DAYS=3

# PagBank
PAGBANK_API_URL=https://api.pagseguro.com
PAGBANK_TOKEN=replace-with-the-production-pagbank-token
PAGBANK_WEBHOOK_SECRET=replace-with-the-production-pagbank-webhook-secret
WEBHOOK_LEASE_SECONDS=60
WEBHOOK_MAX_ATTEMPTS=10

# Workers and outbox
WORKER_ROLE=ALL
WORKER_INSTANCE_ID=
WORKER_POLL_MS=1000
OUTBOX_WORKER_POLL_MS=1000
AI_WORKER_POLL_MS=1000
AUTOMATION_WORKER_POLL_MS=1000
WORKER_STALE_SECONDS=60
OUTBOX_BATCH_SIZE=20
OUTBOX_LEASE_SECONDS=120
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_RETRY_BASE_MS=1000
OUTBOX_RETRY_MAX_MS=300000
OUTBOX_BACKLOG_WARNING_MINUTES=10

# Retention
OUTBOX_RETENTION_DAYS=30
WEBHOOK_RETENTION_DAYS=90
SYSTEM_EVENT_RETENTION_DAYS=90
AUDIT_RETENTION_DAYS=365
RETENTION_CLEANUP_INTERVAL_MS=3600000
RETENTION_CLEANUP_BATCH_SIZE=1000

# Evolution
EVOLUTION_BASE_URL=https://evolution.example.com
EVOLUTION_API_KEY=replace-with-the-production-evolution-api-key
EVOLUTION_INSTANCE_NAME=nutrafit
EVOLUTION_WEBHOOK_SECRET=replace-with-the-evolution-webhook-secret
EVOLUTION_INBOUND_LEASE_SECONDS=120
EVOLUTION_INBOUND_POLL_MS=1000
EVOLUTION_RECOVERY_INTERVAL_MS=30000
EVOLUTION_SEND_LEASE_SECONDS=60

# OpenAI and AI jobs
OPENAI_API_KEY=replace-with-the-production-openai-api-key
OPENAI_MODEL_TEXT=replace-with-the-approved-text-model
OPENAI_MODEL_VISION=replace-with-the-approved-vision-model
OPENAI_TEXT_INPUT_COST_PER_1M_USD=0
OPENAI_TEXT_OUTPUT_COST_PER_1M_USD=0
OPENAI_VISION_INPUT_COST_PER_1M_USD=0
OPENAI_VISION_OUTPUT_COST_PER_1M_USD=0
AI_JOB_LEASE_SECONDS=120
AI_RESERVATION_TTL_SECONDS=300
AI_RECOVERY_INTERVAL_MS=30000

# Storage
UPLOAD_PATH=/var/lib/nutrafit/uploads
MAX_IMAGE_SIZE_MB=10
MAX_AUDIO_SIZE_MB=25
MAX_DOCUMENT_SIZE_MB=25

# Internal cost accounting
ANALYTICS_USD_TO_BRL_RATE=5
ANALYTICS_WHATSAPP_INBOUND_COST_BRL=0
ANALYTICS_WHATSAPP_RESPONSE_COST_BRL=0
ANALYTICS_WHATSAPP_AUTOMATION_COST_BRL=0
ANALYTICS_STORAGE_GB_MONTH_COST_BRL=0

# Operational smoke test
SMOKE_BASE_URL=http://127.0.0.1:3000
SMOKE_ADMIN_EMAIL=admin@example.com
SMOKE_ADMIN_PASSWORD=replace-with-the-admin-password
