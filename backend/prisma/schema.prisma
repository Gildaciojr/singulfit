model PilotCohort {
  id            String            @id @default(uuid())
  name          String
  description   String
  status        PilotCohortStatus @default(PLANNED)
  lastGoStatus  PilotGoStatus?
  goEvaluatedAt DateTime?
  startsAt      DateTime
  endsAt        DateTime
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  participants PilotParticipant[]
  manualChecks PilotManualCheck[]

  @@index([status, startsAt])
  @@index([endsAt])
  @@map("pilot_cohorts")
}

model PilotParticipant {
  id          String                 @id @default(uuid())
  cohortId    String
  userId      String
  status      PilotParticipantStatus @default(INVITED)
  joinedAt    DateTime               @default(now())
  activatedAt DateTime?
  completedAt DateTime?
  droppedAt   DateTime?
  notes       String?

  cohort PilotCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cohortId, userId])
  @@index([cohortId, status, joinedAt])
  @@index([userId, joinedAt])
  @@map("pilot_participants")
}

model PilotManualCheck {
  id              String                 @id @default(uuid())
  cohortId        String
  checkType       PilotManualCheckType
  status          PilotManualCheckStatus @default(PENDING)
  notes           String?
  checkedAt       DateTime
  checkedByUserId String

  cohort    PilotCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  checkedBy User        @relation("PilotCheckOperator", fields: [checkedByUserId], references: [id], onDelete: Restrict)

  @@unique([cohortId, checkType])
  @@index([cohortId, status, checkedAt])
  @@index([checkedByUserId, checkedAt])
  @@map("pilot_manual_checks")
}
