  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, snapshotDate, windowDays])
  @@index([userId, windowDays, calculatedAt])
  @@index([direction, calculatedAt])
  @@map("longitudinal_nutrition_window_snapshots")
}

model OutboundMessage {
  id                String                @id @default(uuid())
  userId            String
  conversationId    String
  sourceMessageId   String
  mealAnalysisId    String?               @unique
  responseType      ResponseType
  content           String
  externalMessageId String?               @unique
  status            OutboundMessageStatus @default(PENDING)
  attempts          Int                   @default(0)
  leaseExpiresAt    DateTime?
  sentAt            DateTime?
  deliveredAt       DateTime?
  failedAt          DateTime?
  errorMessage      String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation       Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sourceMessage      Message               @relation(fields: [sourceMessageId], references: [id], onDelete: Cascade)
  mealAnalysis       MealAnalysis?         @relation(fields: [mealAnalysisId], references: [id], onDelete: Cascade)
  responseEvaluation AIResponseEvaluation?

  @@unique([sourceMessageId, responseType])
  @@index([userId, createdAt])
  @@index([conversationId, createdAt])
  @@index([status, createdAt])
  @@index([status, leaseExpiresAt])
  @@map("outbound_messages")
}

model UsageBucket {
  id              String   @id @default(uuid())
  userId          String
  entitlementCode String
  periodStart     DateTime
  periodEnd       DateTime
  used            Int      @default(0)
  reserved        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  entitlement EntitlementDefinition @relation(fields: [entitlementCode], references: [code], onDelete: Restrict)

  @@unique([userId, entitlementCode, periodStart, periodEnd])
  @@index([userId, entitlementCode, periodEnd])
  @@index([periodEnd])
  @@map("usage_buckets")
}

model UsageEvent {
  id              String           @id @default(uuid())
  userId          String
  aiJobId         String
  entitlementCode String
  quantity        Int
  status          UsageEventStatus @default(RESERVED)
  expiresAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiJob       AIJob                 @relation(fields: [aiJobId], references: [id], onDelete: Cascade)
  entitlement EntitlementDefinition @relation(fields: [entitlementCode], references: [code], onDelete: Restrict)

  @@unique([aiJobId, entitlementCode])
  @@index([userId, entitlementCode, status, createdAt])
  @@index([aiJobId, status])
  @@index([status, expiresAt])
  @@map("usage_events")
}

model UsageDaily {
  id         String   @id @default(uuid())
  userId     String
  date       DateTime
  imagesUsed Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@index([userId])
  @@map("usage_daily")
}

model UserActivation {
  id                             String              @id @default(uuid())
  userId                         String              @unique
  currentStage                   ActivationStage     @default(REGISTERED)
  score                          Int                 @default(5)
  riskLevel                      ActivationRiskLevel @default(LOW)
  registeredAt                   DateTime
  paidAt                         DateTime?
  whatsappConnectedAt            DateTime?
  firstMessageSentAt             DateTime?
  firstMealReceivedAt            DateTime?
  firstAnalysisCompletedAt       DateTime?
  firstRecommendationDeliveredAt DateTime?
  firstCoachInteractionAt        DateTime?
  firstValueAt                   DateTime?
  activatedAt                    DateTime?
  abandonedAt                    DateTime?
  lastProgressAt                 DateTime
  createdAt                      DateTime            @default(now())
  updatedAt                      DateTime            @updatedAt

  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  events    ActivationEvent[]
  snapshots ActivationSnapshot[]

  @@index([currentStage, updatedAt])
  @@index([riskLevel, lastProgressAt])
  @@index([activatedAt])
  @@index([abandonedAt])
  @@map("user_activations")
}

model ActivationEvent {
  id                          String                    @id @default(uuid())
  activationId                String
  userId                      String
  kind                        ActivationEventKind
  eventCode                   String
  idempotencyKey              String                    @unique
  fromStage                   ActivationStage?
  toStage                     ActivationStage?
  source                      String
  occurredAt                  DateTime
  durationFromPreviousSeconds Int?
  metadata                    Json                      @default("{}")
  deliveryStatus              ActivationDeliveryStatus?
  scheduledFor                DateTime?
  sentAt                      DateTime?
  failedAt                    DateTime?
  externalMessageId           String?
  attempts                    Int                       @default(0)
  leaseExpiresAt              DateTime?
  errorMessage                String?
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt

  activation UserActivation @relation(fields: [activationId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([activationId, occurredAt])
  @@index([userId, kind, occurredAt])
  @@index([deliveryStatus, scheduledFor])
  @@index([eventCode, occurredAt])
  @@map("activation_events")
}

model ActivationSnapshot {
  id            String              @id @default(uuid())
  activationId  String
  userId        String
  snapshotDate  DateTime            @db.Date
  currentStage  ActivationStage
  score         Int
  riskLevel     ActivationRiskLevel
  stalledHours  Int
  stepDurations Json
  firstValueAt  DateTime?
  finalStatus   ActivationStage?
  generatedAt   DateTime
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  activation UserActivation @relation(fields: [activationId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, snapshotDate])
  @@index([snapshotDate, currentStage])
  @@index([riskLevel, snapshotDate])
  @@index([activationId, generatedAt])
  @@map("activation_snapshots")
}

