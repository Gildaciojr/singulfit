model User {
  id String @id @default(uuid())

  // IDENTIFICAÇÃO
  phone     String  @unique
  phoneE164 String? @unique
  email     String? @unique
  name      String?

  // AUTENTICAÇÃO
  passwordHash String?
  role         UserRole  @default(USER)
  lastLoginAt  DateTime?

  // DADOS DE NEGÓCIO
  cpf     String?
  address String?
  city    String?
  state   String?
  zipCode String?

  // CONTROLE
  isActive            Boolean @default(true)
  onboardingCompleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions               Subscription[]
  meals                       Meal[]
  usageDaily                  UsageDaily[]
  authSessions                AuthSession[]
  conversations               Conversation[]
  aiJobs                      AIJob[]
  aiUsage                     AIUsage[]
  mediaFiles                  MediaFile[]
  outboundMessages            OutboundMessage[]
  usageBuckets                UsageBucket[]
  usageEvents                 UsageEvent[]
  fitnessProfile              FitnessProfile?
  workoutPlans                WorkoutPlan[]
  dietPlans                   DietPlan[]
  fitnessCheckIns             FitnessCheckIn[]
  progressSnapshots           ProgressSnapshot[]
  progressInsights            ProgressInsight[]
  automationPreference        UserAutomationPreference?
  scheduledMessages           ScheduledMessage[]
  auditLogs                   AuditLog[]
  aiUsageSummaries            AIUsageSummary[]
  nutritionProfile            NutritionProfile?
  preferences                 UserPreferences?
  conversationMemories        ConversationMemory[]
  contextSnapshots            UserContextSnapshot[]
  nutritionScores             NutritionQualityScore[]
  nutritionInsights           NutritionInsight[]
  mealPatterns                MealPattern[]
  nutritionTrends             NutritionTrend[]
  nutritionRecommendations    NutritionRecommendation[]
  coachProfile                CoachProfile?
  goalClassification          UserGoalClassification?
  habitSnapshots              HabitSnapshot[]
  consistencyScores           ConsistencyScore[]
  engagementScores            EngagementScore[]
  churnAssessments            ChurnRiskAssessment[]
  coachMessages               CoachMessage[]
  coachReviews                CoachReview[]
  coachCommunicationProfiles  CoachCommunicationProfileSnapshot[]
  coachMotivationProfiles     CoachMotivationProfileSnapshot[]
  messageFatigueSnapshots     MessageFatigueSnapshot[]
  reengagementClassifications CoachReengagementClassification[]
  goalMomentumSnapshots       GoalMomentumSnapshot[]
  whatsappExperienceSnapshots WhatsAppExperienceSnapshot[]
  retentionStrengthSnapshots  RetentionStrengthSnapshot[]
  nutritionEvidenceSnapshots  NutritionEvidenceSnapshot[]
  foodQualityIndexes          FoodQualityIndex[]
  dietaryPatternSnapshots     DietaryPatternSnapshot[]
  learningProfile             UserLearningProfile?
  communicationAdaptations    CommunicationAdaptationSnapshot[]
  earlyChurnSnapshots         EarlyChurnSnapshot[]
  adaptiveRecommendationRanks AdaptiveRecommendationRank[]
  nutritionWindowSnapshots    LongitudinalNutritionWindowSnapshot[]
  whatsappCostSnapshots       WhatsAppCostSnapshot[]
  storageCostSnapshots        StorageCostSnapshot[]
  profitabilitySnapshots      UserProfitabilitySnapshot[]
  behavioralProfile           BehavioralProfile?
  behavioralMotivations       BehavioralMotivation[]
  stageHistory                StageOfChangeHistory[]
  adherencePredictions        AdherencePrediction[]
  motivationTriggers          MotivationTrigger[]
  behavioralInsights          BehavioralInsight[]
  behavioralSnapshots         BehavioralSnapshot[]
  aiResponseEvaluations       AIResponseEvaluation[]
  aiReviewQueue               AIReviewQueue[]
  recommendations             Recommendation[]
  activation                  UserActivation?
  activationEvents            ActivationEvent[]
  activationSnapshots         ActivationSnapshot[]
  longitudinalProfiles        LongitudinalNutritionProfile[]
  foodPreferenceSnapshots     FoodPreferenceSnapshot[]
  nutritionEvolution          NutritionEvolutionSnapshot[]
  nutritionRelapses           NutritionRelapse[]
  goalProgression             GoalProgressionSnapshot[]
  longitudinalMemories        LongitudinalMemory[]
  coachAdaptations            CoachAdaptationSnapshot[]
  recommendationFeedback      RecommendationFeedbackSnapshot[]
  monthlyEvolutionReviews     MonthlyEvolutionReview[]
  pilotParticipations         PilotParticipant[]
  pilotChecksPerformed        PilotManualCheck[]                    @relation("PilotCheckOperator")

  @@index([isActive])
  @@map("users")
}

model FitnessProfile {
  id              String        @id @default(uuid())
  userId          String        @unique
  gender          Gender
  birthDate       DateTime      @db.Date
  heightCm        Int
  currentWeightKg Decimal       @db.Decimal(6, 2)
  targetWeightKg  Decimal       @db.Decimal(6, 2)
  activityLevel   ActivityLevel
  goal            FitnessGoal
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodRestrictions   FoodRestriction[]
  injuryRestrictions InjuryRestriction[]
  bodyMeasurements   BodyMeasurement[]
  workoutPlans       WorkoutPlan[]
  dietPlans          DietPlan[]
  fitnessCheckIns    FitnessCheckIn[]
  progressSnapshots  ProgressSnapshot[]

  @@map("fitness_profiles")
}

model NutritionProfile {
  id                String        @id @default(uuid())
  userId            String        @unique
  sex               Gender
  birthDate         DateTime      @db.Date
  heightCm          Int
  currentWeightKg   Decimal       @db.Decimal(6, 2)
  targetWeightKg    Decimal       @db.Decimal(6, 2)
  activityLevel     ActivityLevel
  goal              FitnessGoal
  restrictions      Json          @default("[]")
  allergies         Json          @default("[]")
  medicalConditions Json          @default("[]")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([goal, activityLevel])
  @@map("nutrition_profiles")
}

model UserPreferences {
  id                    String   @id @default(uuid())
  userId                String   @unique
  preferredWakeUpTime   String?
  preferredSleepTime    String?
  preferredTrainingTime String?
  preferredMealTimes    Json     @default("[]")
  preferredLanguage     String   @default("pt-BR")
  timezone              String   @default("America/Sao_Paulo")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([timezone])
  @@map("user_preferences")
}

model ConversationMemory {
  id             String     @id @default(uuid())
  userId         String
  memoryType     MemoryType
  sourceKey      String?
  content        Json
  summary        String
  relevanceScore Decimal    @db.Decimal(5, 4)
  generatedAt    DateTime
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, memoryType, sourceKey])
  @@index([userId, relevanceScore, generatedAt])
  @@index([userId, memoryType, generatedAt])
  @@map("conversation_memories")
}

model UserContextSnapshot {
  id                     String         @id @default(uuid())
  userId                 String
  refreshKey             String         @unique
  weightKg               Decimal?       @db.Decimal(6, 2)
  goal                   FitnessGoal?
  activityLevel          ActivityLevel?
  lastInteractionAt      DateTime?
  messagesLast7Days      Int
  messagesLast30Days     Int
  nutritionAnalysesCount Int
  adherenceScore         Int?
  generatedAt            DateTime
  createdAt              DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, generatedAt])
  @@index([generatedAt])
  @@map("user_context_snapshots")
}

model FoodRestriction {
  id          String @id @default(uuid())
  profileId   String
  type        String
  description String

  profile FitnessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("food_restrictions")
}

model InjuryRestriction {
  id          String @id @default(uuid())
  profileId   String
  description String

  profile FitnessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("injury_restrictions")
}

model BodyMeasurement {
  id             String   @id @default(uuid())
  profileId      String
  weightKg       Decimal  @db.Decimal(6, 2)
  bodyFatPercent Decimal? @db.Decimal(5, 2)
  muscleMassKg   Decimal? @db.Decimal(6, 2)
  measuredAt     DateTime @default(now())

  profile FitnessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, measuredAt])
  @@map("body_measurements")
}

model FitnessCheckIn {
  id             String      @id @default(uuid())
  userId         String
  profileId      String
  mood           String
  energyLevel    EnergyLevel
  adherenceScore Int
  notes          String?
  createdAt      DateTime    @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile FitnessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([profileId, createdAt])
  @@map("fitness_check_ins")
}

model ProgressSnapshot {
  id             String   @id @default(uuid())
  userId         String
  profileId      String
  weightKg       Decimal  @db.Decimal(6, 2)
  bodyFatPercent Decimal? @db.Decimal(5, 2)
  muscleMassKg   Decimal? @db.Decimal(6, 2)
  bmi            Decimal  @db.Decimal(5, 2)
  createdAt      DateTime @default(now())

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile  FitnessProfile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  insights ProgressInsight[]

  @@index([userId, createdAt])
  @@index([profileId, createdAt])
  @@map("progress_snapshots")
}

model ProgressInsight {
  id         String   @id @default(uuid())
  userId     String
  snapshotId String
  aiJobId    String?  @unique
  insight    String
  createdAt  DateTime @default(now())

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshot ProgressSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  aiJob    AIJob?           @relation(fields: [aiJobId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([snapshotId, createdAt])
  @@map("progress_insights")
}

model WorkoutPlan {
  id          String        @id @default(uuid())
  userId      String
  profileId   String
  aiJobId     String?       @unique
  title       String
  objective   FitnessGoal
  status      WorkoutStatus @default(ACTIVE)
  generatedAt DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile FitnessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  aiJob   AIJob?         @relation(fields: [aiJobId], references: [id], onDelete: Restrict)
  days    WorkoutDay[]

  @@index([userId, status, generatedAt])
  @@index([profileId, generatedAt])
  @@map("workout_plans")
}

model WorkoutDay {
  id            String @id @default(uuid())
  workoutPlanId String
  dayNumber     Int
  title         String

  workoutPlan WorkoutPlan       @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  exercises   WorkoutExercise[]

  @@unique([workoutPlanId, dayNumber])
  @@index([workoutPlanId])
  @@map("workout_days")
}

model WorkoutExercise {
  id           String  @id @default(uuid())
  workoutDayId String
  exerciseName String
  sets         Int
  reps         String
  restSeconds  Int
  notes        String?

  workoutDay WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)

  @@index([workoutDayId])
  @@map("workout_exercises")
}

model DietPlan {
  id                  String         @id @default(uuid())
  userId              String
  profileId           String
  aiJobId             String         @unique
  title               String
  objective           FitnessGoal
  dailyCaloriesTarget Decimal        @db.Decimal(8, 2)
  proteinTarget       Decimal        @db.Decimal(8, 2)
  carbsTarget         Decimal        @db.Decimal(8, 2)
  fatTarget           Decimal        @db.Decimal(8, 2)
  status              DietPlanStatus @default(ACTIVE)
  generatedAt         DateTime       @default(now())
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile FitnessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  aiJob   AIJob          @relation(fields: [aiJobId], references: [id], onDelete: Restrict)
  meals   DietMeal[]

  @@index([userId, status, generatedAt])
  @@index([profileId, generatedAt])
  @@map("diet_plans")
}

model DietMeal {
  id             String  @id @default(uuid())
  dietPlanId     String
  name           String
  order          Int
  caloriesTarget Decimal @db.Decimal(8, 2)
  notes          String?

  dietPlan DietPlan       @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)
  items    DietMealItem[]

  @@unique([dietPlanId, order])
  @@index([dietPlanId])
  @@map("diet_meals")
}

model DietMealItem {
  id                String  @id @default(uuid())
  dietMealId        String
  foodName          String
  quantity          String
  calories          Decimal @db.Decimal(8, 2)
  protein           Decimal @db.Decimal(8, 2)
  carbs             Decimal @db.Decimal(8, 2)
  fat               Decimal @db.Decimal(8, 2)
  substitutionGroup String?

  dietMeal DietMeal @relation(fields: [dietMealId], references: [id], onDelete: Cascade)

  @@index([dietMealId])
  @@map("diet_meal_items")
}

model AutomationRule {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  scheduledMessages ScheduledMessage[]

  @@index([enabled])
  @@map("automation_rules")
}

model UserAutomationPreference {
  id                       String   @id @default(uuid())
  userId                   String   @unique
  remindersEnabled         Boolean  @default(true)
  workoutReminderEnabled   Boolean  @default(true)
  mealReminderEnabled      Boolean  @default(true)
  hydrationReminderEnabled Boolean  @default(true)
  progressReminderEnabled  Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_automation_preferences")
}

model ScheduledMessage {
  id               String                 @id @default(uuid())
  userId           String
  automationRuleId String
  scheduledFor     DateTime
  status           ScheduledMessageStatus @default(PENDING)
  content          String
  attempts         Int                    @default(0)
  leaseExpiresAt   DateTime?
  createdAt        DateTime               @default(now())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  automationRule AutomationRule @relation(fields: [automationRuleId], references: [id], onDelete: Restrict)

  @@unique([userId, automationRuleId, scheduledFor])
  @@index([status, scheduledFor])
  @@index([status, leaseExpiresAt])
  @@index([userId, scheduledFor])
  @@map("scheduled_messages")
}

model AuthSession {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String
  jti              String    @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, revokedAt])
  @@map("auth_sessions")
}

model Plan {
  id                   String          @id @default(uuid())
  type                 PlanType        @unique
