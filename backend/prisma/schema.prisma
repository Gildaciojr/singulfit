model Subscription {
  id                  String             @id @default(uuid())
  userId              String
  planId              String
  activationInvoiceId String?            @unique
  status              SubscriptionStatus @default(PENDING_PAYMENT)

  // CICLO DE ASSINATURA (fonte de verdade)
  startedAt          DateTime?
  billingPeriodStart DateTime?
  billingPeriodEnd   DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  gracePeriodEnd     DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  canceledAt         DateTime?
  endedAt            DateTime?

  // PAGAMENTO / INTEGRAÇÃO
  provider               PaymentProvider?
  externalSubscriptionId String?
  amount                 Decimal          @db.Decimal(10, 2)
  externalPaymentId      String?          @unique
  paymentMethod          PaymentMethod?
  paidAt                 DateTime?
  version                Int              @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              Plan           @relation(fields: [planId], references: [id])
  invoices          Invoice[]      @relation("SubscriptionInvoices")
  activationInvoice Invoice?       @relation("SubscriptionActivationInvoice", fields: [activationInvoiceId], references: [id], onDelete: Restrict)
  conversations     Conversation[]

  @@unique([provider, externalSubscriptionId])
  // PERFORMANCE + CONSULTA
  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([userId, status])
  @@index([billingPeriodEnd])
  @@index([userId, billingPeriodEnd])
  @@index([currentPeriodEnd])
  @@index([gracePeriodEnd])
  @@map("subscriptions")
}

